{
  "name": "hoc-tu-thien",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "prisma db push --accept-data-loss && next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run prisma:seed",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=src/__tests__/unit --passWithNoTests",
    "test:integration": "jest --testPathPattern=integration --passWithNoTests --runInBand",
    "test:e2e-ui": "E2E_TEST_MODE=true playwright test",
    "test:e2e-ui:ui": "E2E_TEST_MODE=true playwright test --ui",
    "test:ci": "jest --ci --coverage --forceExit --runInBand"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "^5.16.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "https-proxy-agent": "^5.0.1",
    "lucide-react": "^0.471.2",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.20",
    "prisma": "^5.16.1",
    "react": "^18",
    "react-dom": "^18",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.1",
    "undici": "^7.24.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.37",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.27",
    "eslint": "^8",
    "eslint-config-next": "^14.2.35",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
