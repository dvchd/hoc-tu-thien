# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (development)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production) - uncomment and update prisma/schema.prisma provider
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hoc_tu_thien?schema=public"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_A_STRONG_RANDOM_SECRET_32_CHARS"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# ─── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Học Từ Thiện"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Thiện Nguyện App ──────────────────────────────────────────────────────────
# Số tài khoản TN App dùng cho Activation (kích hoạt tài khoản 10k)
TN_ACTIVATION_ACCOUNT_NO="2000"
TN_ACTIVATION_ACCOUNT_NAME="QUY THIEN NGUYEN"

# ─── Seed ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="your@gmail.com"
DEMO_MENTEE_EMAIL="mentee@demo.com"
